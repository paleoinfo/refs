# ============================================================
# REFS - Document Gallery con Integrazione SSO
# ============================================================
# Copia questo file in .env e configurare i valori

# ============================================================
# FLASK CONFIGURATION
# ============================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=3010

# ============================================================
# SSO CONFIGURATION - Valida JWT emessi da Checkin
# ============================================================
SSO_MODE=dev
JWT_SECRET=
JWT_ALGORITHM=HS256
PORTAL_URL=http://localhost:5000
APP_AUDIENCE=refs-app

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
SERVER_SECRET_KEY=dev-secret-change-in-production
DEBUG=False

# ============================================================
# USER AND RATE LIMITING
# ============================================================
DEV_USER_EMAIL=demo@example.com
MAX_SESSIONS_PER_USER=3
MAX_SESSIONS_GLOBAL=100

# ============================================================
# UPLOAD CONFIGURATION
# ============================================================
# Cartella per i file caricati
UPLOAD_FOLDER=/app/uploads

# Formati di file consentiti (PDF, immagini)
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,gif,bmp

# Limite massimo dimensione upload (in bytes)
# 16MB default (16777216 bytes)
MAX_CONTENT_LENGTH=16777216

# ============================================================
# FILE PROCESSING
# ============================================================
# Numero massimo di pagine da processare per PDF
MAX_PDF_PAGES=500

# Qualità thumbnail (1-100)
THUMBNAIL_QUALITY=85
